import os
import numpy as np
import tensorflow as tf
from tensorflow.keras import layers, models, optimizers, Input
from tensorflow.keras.utils import to_categorical
from sklearn.metrics import classification_report, confusion_matrix, roc_curve, auc
import matplotlib.pyplot as plt
import seaborn as sns
import gc

# ==========================================
# 1. CONFIGURATION
# ==========================================

CONFIG = {
    'BASE_PATH': '/content/drive/MyDrive/Multimodal_Deep-Learning_for_Early_Detection_and_Classification_of_Brain_Tumors/Datasets/Balanced_Multimodal/CT',
    'INPUT_SHAPE': (224, 224, 4), # From preprocessing
    'PATCH_SIZE': 28,             # 224 / 8 = 28
    'NUM_PATCHES': 64,            # 8 * 8 grid
    'NUM_CLASSES': 2,             # Binary: Normal vs Tumor (as per Slide 19)
    'BATCH_SIZE': 32,
    'EPOCHS': 20,
    'LEARNING_RATE': 0.0001       # Lower LR often better for complex architectures
}

CLASS_NAMES = ['Normal', 'Tumor']

# ==========================================
# 2. DATA GENERATOR (CT Specific)
# ==========================================

class CTDataGenerator(tf.keras.utils.Sequence):
    """
    Generates data for CT Model.
    Focuses on Binary Classification (Normal vs Tumor).
    """
    def __init__(self, directory, batch_size=32, shuffle=True, input_shape=(224,224,4)):
        self.directory = directory
        self.batch_size = batch_size
        self.shuffle = shuffle
        self.input_shape = input_shape
        self.file_list = []
        self.labels = []
        self._scan_directory()
        self.on_epoch_end()

    def _scan_directory(self):
        # CT folders: CT/train/normal, CT/train/tumor
        for label_name in ['normal', 'tumor']:
            path = os.path.join(self.directory, label_name)
            if not os.path.exists(path): continue
            
            label_idx = 0 if label_name == 'normal' else 1
            
            for f in os.listdir(path):
                if f.endswith('.npy'):
                    self.file_list.append(os.path.join(path, f))
                    self.labels.append(label_idx)

    def __len__(self):
        return int(np.floor(len(self.file_list) / self.batch_size))

    def __getitem__(self, index):
        indexes = self.indexes[index*self.batch_size:(index+1)*self.batch_size]
        file_batch = [self.file_list[k] for k in indexes]
        label_batch = [self.labels[k] for k in indexes]

        X, y = self.__data_generation(file_batch, label_batch)
        return X, y

    def on_epoch_end(self):
        self.indexes = np.arange(len(self.file_list))
        if self.shuffle:
            np.random.shuffle(self.indexes)

    def __data_generation(self, file_batch, label_batch):
        X = np.empty((self.batch_size, *self.input_shape))
        y = np.empty((self.batch_size), dtype=int)

        for i, f_path in enumerate(file_batch):
            img = np.load(f_path)
            # Ensure shape consistency
            if img.shape != self.input_shape:
                img = tf.image.resize(img, (self.input_shape[0], self.input_shape[1])).numpy()
            X[i,] = img
            y[i] = label_batch[i]

        return X, to_categorical(y, num_classes=CONFIG['NUM_CLASSES'])

# ==========================================
# 3. CORRELATION LEARNING ARCHITECTURE
# ==========================================

class CorrelationLayer(layers.Layer):
    """
    Computes pairwise correlation between patch features.
    Input: (Batch, Num_Patches, Features)
    Output: (Batch, Num_Patches, Num_Patches) -> The Correlation Matrix
    """
    def call(self, inputs):
        # Matrix multiplication of Features with Features Transposed
        # Computes similarity between every patch and every other patch
        # Shape: (B, N, F) . (B, F, N) = (B, N, N)
        return tf.matmul(inputs, inputs, transpose_b=True)

def build_ct_correlation_model(input_shape):
    """
    Implements the Patch-Based Correlation Learning Model.
    1. Split Image -> Patches
    2. Shared Encoder -> Feature Vector per Patch
    3. Correlation Layer -> Inter-regional relationships
    4. Classifier -> Tumor/No Tumor
    """
    inputs = Input(shape=input_shape)
    
    # 1. Extract Patches
    # Convert image to patches (Batch, Patch_H, Patch_W, Channels)
    # 224x224 divided by 28x28 patches = 8x8 grid = 64 patches
    patch_size = CONFIG['PATCH_SIZE']
    patches = tf.image.extract_patches(
        images=inputs,
        sizes=[1, patch_size, patch_size, 1],
        strides=[1, patch_size, patch_size, 1],
        rates=[1, 1, 1, 1],
        padding='VALID'
    )
    
    # Reshape patches to (Batch, Num_Patches, Patch_Dims)
    # Patch dims = 28 * 28 * 4 = 3136
    patches_reshaped = layers.Reshape((CONFIG['NUM_PATCHES'], -1))(patches)
    
    # Reshape again to image-like for the CNN encoder: (Batch, Num_Patches, 28, 28, 4)
    patches_img = layers.Reshape((CONFIG['NUM_PATCHES'], patch_size, patch_size, input_shape[-1]))(patches_reshaped)

    # 2. Shared CNN Encoder
    # We use TimeDistributed to apply the SAME CNN to every patch independently
    encoder = models.Sequential([
        layers.Conv2D(32, (3, 3), activation='relu', padding='same', input_shape=(patch_size, patch_size, input_shape[-1])),
        layers.MaxPooling2D((2, 2)),
        layers.Conv2D(64, (3, 3), activation='relu', padding='same'),
        layers.MaxPooling2D((2, 2)),
        layers.Flatten(),
        layers.Dense(128, activation='relu'), # Feature vector size 128
        layers.LayerNormalization() # Normalize for stable correlation
    ], name="shared_encoder")
    
    # Extract features: Shape (Batch, 64, 128)
    patch_features = layers.TimeDistributed(encoder)(patches_img)
    
    # 3. Correlation Learning Mechanism
    # Compute correlation matrix: Shape (Batch, 64, 64)
    correlation_matrix = CorrelationLayer(name="correlation_layer")(patch_features)
    
    # 4. Classification Head
    # Flatten the correlation matrix (captures global structure)
    flat_matrix = layers.Flatten()(correlation_matrix)
    
    x = layers.Dense(256, activation='relu')(flat_matrix)
    x = layers.Dropout(0.5)(x)
    x = layers.Dense(32, activation='relu')(x)
    
    outputs = layers.Dense(CONFIG['NUM_CLASSES'], activation='softmax')(x)
    
    model = models.Model(inputs=inputs, outputs=outputs, name="CT_Correlation_Model")
    return model

# ==========================================
# 4. EXECUTION & TRAINING
# ==========================================

def run_ct_classification():
    print("--- 1. Initializing CT Data Generators ---")
    train_dir = os.path.join(CONFIG['BASE_PATH'], 'train')
    val_dir = os.path.join(CONFIG['BASE_PATH'], 'val')
    test_dir = os.path.join(CONFIG['BASE_PATH'], 'test')
    
    train_gen = CTDataGenerator(train_dir, batch_size=CONFIG['BATCH_SIZE'], input_shape=CONFIG['INPUT_SHAPE'])
    val_gen = CTDataGenerator(val_dir, batch_size=CONFIG['BATCH_SIZE'], shuffle=False, input_shape=CONFIG['INPUT_SHAPE'])
    test_gen = CTDataGenerator(test_dir, batch_size=CONFIG['BATCH_SIZE'], shuffle=False, input_shape=CONFIG['INPUT_SHAPE'])
    
    print(f"Training Batches: {len(train_gen)}")
    
    print("\n--- 2. Building Correlation Learning Model ---")
    model = build_ct_correlation_model(CONFIG['INPUT_SHAPE'])
    model.compile(optimizer=optimizers.Adam(learning_rate=CONFIG['LEARNING_RATE']),
                  loss='categorical_crossentropy',
                  metrics=['accuracy'])
    
    model.summary()
    
    print("\n--- 3. Training ---")
    history = model.fit(
        train_gen,
        epochs=CONFIG['EPOCHS'],
        validation_data=val_gen,
        verbose=1
    )
    
    # Plot Training History
    plt.figure(figsize=(12, 4))
    plt.subplot(1, 2, 1)
    plt.plot(history.history['accuracy'], label='Train')
    plt.plot(history.history['val_accuracy'], label='Val')
    plt.title('CT Model Accuracy')
    plt.legend()
    plt.subplot(1, 2, 2)
    plt.plot(history.history['loss'], label='Train')
    plt.plot(history.history['val_loss'], label='Val')
    plt.title('CT Model Loss')
    plt.legend()
    plt.show()
    
    print("\n--- 4. Evaluation & Results ---")
    # Predict
    print("Generating predictions...")
    # Get true labels from generator (need to iterate carefully or regenerate)
    y_true = []
    y_pred_probs = []
    
    # Iterate through test generator
    for i in range(len(test_gen)):
        X, y = test_gen[i]
        preds = model.predict_on_batch(X)
        y_true.extend(np.argmax(y, axis=1))
        y_pred_probs.extend(preds)
        
    y_true = np.array(y_true)
    y_pred_probs = np.array(y_pred_probs)
    y_pred = np.argmax(y_pred_probs, axis=1)
    
    # Classification Report
    print("\nClassification Report:")
    print(classification_report(y_true, y_pred, target_names=CLASS_NAMES))
    
    # Confusion Matrix
    cm = confusion_matrix(y_true, y_pred)
    plt.figure(figsize=(6, 5))
    sns.heatmap(cm, annot=True, fmt='d', cmap='Reds', xticklabels=CLASS_NAMES, yticklabels=CLASS_NAMES)
    plt.title('Confusion Matrix: CT Correlation Model')
    plt.ylabel('True Label')
    plt.xlabel('Predicted Label')
    plt.show()
    
    # ROC Curve (Binary)
    fpr, tpr, _ = roc_curve(y_true, y_pred_probs[:, 1])
    roc_auc = auc(fpr, tpr)
    
    plt.figure(figsize=(8, 6))
    plt.plot(fpr, tpr, color='darkorange', lw=2, label=f'CT ROC curve (area = {roc_auc:.4f})')
    plt.plot([0, 1], [0, 1], color='navy', lw=2, linestyle='--')
    plt.xlim([0.0, 1.0])
    plt.ylim([0.0, 1.05])
    plt.xlabel('False Positive Rate')
    plt.ylabel('True Positive Rate')
    plt.title('Receiver Operating Characteristic - CT Model')
    plt.legend(loc="lower right")
    plt.show()

# Run the pipeline
if __name__ == "__main__":
    if os.path.exists(CONFIG['BASE_PATH']):
        run_ct_classification()
    else:
        print(f"Error: Path not found {CONFIG['BASE_PATH']}")